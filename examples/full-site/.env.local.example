MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=premast_example
# AUTH_SECRET — any 32-byte hex string is fine for local dev.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Public site URL — used by sitemap.xml and robots.txt for absolute URLs
SITE_URL=http://localhost:3000

# ---- Media plugin (@premast/site-plugin-media) --------------------
# Only required if you install the media plugin (`npm run add-plugin`).
# Uploads go directly from the browser to DigitalOcean Spaces (or any
# S3-compatible bucket) via presigned URLs.
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_KEY=
DO_SPACES_SECRET=
# Optional: CDN endpoint to serve files from (falls back to the
# virtual-hosted Spaces URL if unset).
DO_SPACES_CDN_URL=
# Optional: key prefix inside the bucket (e.g. "uploads/"). Leave
# blank to store at the bucket root.
DO_SPACES_PREFIX=
